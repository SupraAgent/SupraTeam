# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Encryption (AES-256-GCM for token storage)
TOKEN_ENCRYPTION_KEY=

# Telegram Bot (Phase 2)
TELEGRAM_BOT_TOKEN=

# Telegram User Auth (browser-side GramJS for TG Connect)
# Get from: https://my.telegram.org > API Development Tools
NEXT_PUBLIC_TELEGRAM_API_ID=
NEXT_PUBLIC_TELEGRAM_API_HASH=

# Google OAuth (Gmail integration)
# Create at: https://console.cloud.google.com/apis/credentials
# Set redirect URI to: {NEXT_PUBLIC_APP_URL}/api/email/callback/gmail
# IMPORTANT: If your OAuth consent screen is in "Testing" mode, refresh tokens expire
# after 7 days. Switch to "Internal" (Workspace) or publish the app to avoid this.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# App URL (used for OAuth redirects and Pub/Sub audience verification)
NEXT_PUBLIC_APP_URL=http://localhost:3002

# Google Pub/Sub (real-time email push notifications)
# Without this, email falls back to 120-second polling.
# Setup: create a Pub/Sub topic, grant gmail-api-push@system.gserviceaccount.com publish rights,
# create a push subscription pointing to {NEXT_PUBLIC_APP_URL}/api/email/webhook/gmail
GOOGLE_PUBSUB_TOPIC=

# Calendly OAuth (scheduling integration)
# Create at: https://developer.calendly.com > OAuth Applications
# Set redirect URI to: {NEXT_PUBLIC_APP_URL}/api/calendly/callback
CALENDLY_CLIENT_ID=
CALENDLY_CLIENT_SECRET=
CALENDLY_WEBHOOK_SIGNING_KEY=

# Cron job authentication (used by no-show detection, Fireflies reconciliation)
CRON_SECRET=

# Claude AI features (email drafts, summaries, categorization)
ANTHROPIC_API_KEY=
